DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ucuncugoz

# Google Cloud
GCP_PROJECT=your-gcp-project-id
GCS_BUCKET=ucuncugoz-videos
# Local dev only: path to a service account JSON. Leave empty in Cloud Run
# (the runtime service account is auto-detected via google.auth.default()).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json

# Video Intelligence
VIDEO_INTELLIGENCE_MIN_CONFIDENCE=0.6

# CORS
CORS_ORIGINS=http://localhost:3000
